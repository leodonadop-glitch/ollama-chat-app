# Configuración de LD IA Model

# Puerto del servidor
PORT=3000

# Backend principal (por defecto: 'ollama' o 'lm-studio')
BACKEND=ollama

# URL de la API de Ollama
OLLAMA_API=http://localhost:11434/api/generate

# URL de la API de LM Studio (compatible con OpenAI)
LM_STUDIO_API=http://localhost:1234/v1/chat/completions

# Modelo por defecto (llama2, neural-chat, mistral, etc.)
MODEL=llama2
